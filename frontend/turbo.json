{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "codegen"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": [],
      "dependsOn": ["codegen"]
    },
    "typecheck": {
      "outputs": [],
      "dependsOn": ["^build", "codegen"]
    },
    "test": {
      "outputs": ["coverage/**"],
      "dependsOn": ["codegen"]
    },
    "codegen": {
      "inputs": ["codegen.ts", "src/lib/graphql-client.ts", "../bff-*/src/schema.graphql"],
      "outputs": ["src/__generated__/**"]
    }
  }
}
