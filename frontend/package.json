{
  "name": "@inventory/frontend",
  "version": "0.0.1",
  "private": true,
  "description": "Frontend monorepo (4 BFFs + 4 Web UIs). See README.md for layout.",
  "engines": {
    "node": ">=20.10",
    "pnpm": ">=9.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yaml,yml,graphql,graphqls}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yaml,yml,graphql,graphqls}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "^6.0.0"
    }
  }
}
