<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.inventory.wholesale.adapter.out.persistence.PartnerPriceMapper">

    <resultMap id="partnerPriceRow"
               type="com.example.inventory.wholesale.adapter.out.persistence.PartnerPriceRow">
        <constructor>
            <idArg column="partner_code" javaType="java.lang.String"/>
            <idArg column="sku_code" javaType="java.lang.String"/>
            <idArg column="price_tier" javaType="java.lang.String"/>
            <arg column="unit_price" javaType="java.math.BigDecimal"/>
            <arg column="currency" javaType="java.lang.String"/>
        </constructor>
    </resultMap>

    <select id="findCurrent" resultMap="partnerPriceRow">
        SELECT partner_code, sku_code, price_tier, unit_price, currency
        FROM partner_price
        WHERE partner_code = #{partnerCode}
          AND sku_code = #{skuCode}
          AND price_tier = #{priceTier}
          AND valid_from &lt;= now()
          AND (valid_to IS NULL OR valid_to &gt; now())
    </select>

</mapper>
